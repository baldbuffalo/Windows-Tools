<Window x:Class="WindowsTools.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:WindowsTools.Views"
        Title="Windows Tools"
        Height="680"
        Width="1000"
        MinHeight="500"
        MinWidth="750"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF333333"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFE81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- OEM app launch button style -->
        <Style x:Key="OemAppButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Margin="8,1">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF2A2A2A"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Background="{StaticResource SidebarBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="⚙" FontSize="14" Foreground="{StaticResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Windows Tools" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource TitleBarButtonStyle}" Content="—" Click="Minimize_Click"/>
                    <Button Style="{StaticResource TitleBarButtonStyle}" Content="⬜" Click="Maximize_Click"/>
                    <Button Style="{StaticResource CloseButtonStyle}" Content="✕" Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- Main Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="{StaticResource SidebarBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- App Brand -->
                        <StackPanel Grid.Row="0" Margin="16,20,16,16">
                            <Border Width="48" Height="48" Background="{StaticResource AccentBrush}"
                                    CornerRadius="12" HorizontalAlignment="Left">
                                <TextBlock Text="🛠" FontSize="24"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Windows Tools" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,10,0,2"/>
                            <TextBlock Text="System Utilities" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>

                        <Rectangle Grid.Row="0" Height="1" Fill="{StaticResource BorderBrush}"
                                   VerticalAlignment="Bottom" Margin="16,0"/>

                        <!-- Navigation -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,12,0,0">
                                <TextBlock Text="TOOLS" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="24,8,0,6"/>

                                <Button x:Name="StorageNavButton"
                                        Style="{StaticResource NavButtonActiveStyle}"
                                        Click="StorageNavButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="💾" FontSize="15" VerticalAlignment="Center"/>
                                        <TextBlock Text="Storage" FontSize="14" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="DriverHubNavButton"
                                        Style="{StaticResource NavButtonStyle}"
                                        Click="DriverHubNavButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔧" FontSize="15" VerticalAlignment="Center"/>
                                        <TextBlock Text="Driver Hub" FontSize="14" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource NavButtonStyle}" IsEnabled="False" Opacity="0.4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📊" FontSize="15" VerticalAlignment="Center"/>
                                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Performance" FontSize="14"/>
                                            <TextBlock Text="Coming soon" FontSize="9" Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource NavButtonStyle}" IsEnabled="False" Opacity="0.4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔒" FontSize="15" VerticalAlignment="Center"/>
                                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Privacy" FontSize="14"/>
                                            <TextBlock Text="Coming soon" FontSize="9" Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource NavButtonStyle}" IsEnabled="False" Opacity="0.4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🌐" FontSize="15" VerticalAlignment="Center"/>
                                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Network" FontSize="14"/>
                                            <TextBlock Text="Coming soon" FontSize="9" Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Button>

                                <!-- YOUR APPS — dynamically populated after OEM installs -->
                                <StackPanel x:Name="YourAppsSection">
                                    <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="16,12,16,0"/>
                                    <TextBlock Text="YOUR APPS" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMutedBrush}" Margin="24,10,0,4"/>
                                    <ItemsControl x:Name="InstalledAppsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource OemAppButtonStyle}"
                                                        Command="{Binding LaunchCommand}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Name}" FontSize="13"
                                                                   Margin="9,0,0,0" VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis" MaxWidth="130"/>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Version -->
                        <TextBlock Grid.Row="2" Text="v1.0.0" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="24,0,0,16"/>
                    </Grid>
                </Border>

                <!-- Page Content -->
                <Border Grid.Column="1" Background="{StaticResource BackgroundBrush}">
                    <ContentControl x:Name="PageContent">
                        <views:StorageView/>
                    </ContentControl>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
