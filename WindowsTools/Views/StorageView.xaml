<UserControl x:Class="WindowsTools.Views.StorageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WindowsTools.Converters"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <conv:PercentToColorConverter x:Key="PercentToColor"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </UserControl.Resources>

    <Grid Margin="32,28,32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Storage"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding LastRefreshed}"
                           FontSize="12"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="⟳  Refresh"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="RefreshButton_Click"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- Summary Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total Storage Card -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0">
                <StackPanel>
                    <TextBlock Text="Total Storage"
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding TotalSystemStorage}"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Fixed drives combined"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Used Storage Card -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0">
                <StackPanel>
                    <TextBlock Text="Used Space"
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding TotalUsedStorage}"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="Across all fixed drives"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Free Storage Card -->
            <Border Grid.Column="4" Style="{StaticResource CardStyle}" Margin="0">
                <StackPanel>
                    <TextBlock Text="Free Space"
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding TotalFreeStorage}"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource GreenBrush}"/>
                    <TextBlock Text="Available across fixed drives"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Drive List -->
        <Grid Grid.Row="2">
            <!-- Loading Indicator -->
            <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="Loading drives..."
                           FontSize="16"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Drives -->
            <ScrollViewer Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibility}}"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Drives}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Drive Header -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Drive Icon -->
                                        <Border Grid.Column="0"
                                                Width="44" Height="44"
                                                Background="#FF2E2E2E"
                                                CornerRadius="8">
                                            <TextBlock Text="{Binding DriveTypeIcon}"
                                                       FontSize="22"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Drive Name + Info -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding DriveLetter}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Label}"
                                                           FontSize="15"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="6,0,0,0"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <TextBlock Text="{Binding DriveType}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}"/>
                                                <TextBlock Text=" · "
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding FileSystem}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Used / Total -->
                                        <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                                                       HorizontalAlignment="Right">
                                                <Run Text="{Binding UsedSpaceFormatted}"/>
                                                <Run Text=" / " Foreground="{StaticResource TextMutedBrush}"/>
                                                <Run Text="{Binding TotalSizeFormatted}" Foreground="{StaticResource TextMutedBrush}"/>
                                            </TextBlock>
                                            <TextBlock HorizontalAlignment="Right" Margin="0,3,0,0">
                                                <Run Text="{Binding UsedPercent, StringFormat={}{0:F1}}"
                                                     FontSize="13"
                                                     FontWeight="Bold"
                                                     Foreground="{Binding UsedPercent, Converter={StaticResource PercentToColor}}"/>
                                                <Run Text="% used"
                                                     FontSize="11"
                                                     Foreground="{StaticResource TextMutedBrush}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Progress Bar Track -->
                                    <Border Grid.Row="2"
                                            Height="8"
                                            Background="#FF333333"
                                            CornerRadius="4">
                                        <Grid>
                                            <Border HorizontalAlignment="Left"
                                                    Height="8"
                                                    CornerRadius="4"
                                                    Background="{Binding UsedPercent, Converter={StaticResource PercentToColor}}">
                                                <Border.Width>
                                                    <MultiBinding>
                                                        <MultiBinding.Converter>
                                                            <conv:PercentToWidthConverter/>
                                                        </MultiBinding.Converter>
                                                        <Binding Path="UsedPercent"/>
                                                        <Binding RelativeSource="{RelativeSource AncestorType=Border}" Path="ActualWidth"/>
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Space Details -->
                                    <Grid Grid.Row="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Border Width="8" Height="8" CornerRadius="2"
                                                    Background="{Binding UsedPercent, Converter={StaticResource PercentToColor}}"
                                                    VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}">
                                                <Run Text="Used: "/>
                                                <Run Text="{Binding UsedSpaceFormatted}" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Border Width="8" Height="8" CornerRadius="2"
                                                    Background="#FF333333"
                                                    VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}">
                                                <Run Text="Free: "/>
                                                <Run Text="{Binding FreeSpaceFormatted}" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
