<UserControl x:Class="WindowsTools.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WindowsTools.Converters"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,28,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Settings" FontSize="28" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="Preferences and updates" FontSize="12"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- General -->
            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                <TextBlock Text="GENERAL" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"/>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <CheckBox Content="Check for updates on startup"
                                  IsChecked="{Binding CheckUpdatesOnStartup}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  FontSize="14"/>
                        <CheckBox Content="Automatically install detected driver apps"
                                  IsChecked="{Binding AutoInstallDrivers}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  FontSize="14" Margin="0,14,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- About / Update -->
            <StackPanel Grid.Row="2">
                <TextBlock Text="ABOUT &amp; UPDATES" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,10"/>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <!-- Version -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Windows Tools" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding AppVersion}" FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Open install folder"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding OpenInstallFolderCommand}"
                                    VerticalAlignment="Center"/>
                        </Grid>

                        <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,16"/>

                        <!-- Hash comparison -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="INSTALLED (SHA-256)" FontSize="9" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="{Binding LocalHashShort}" FontSize="12"
                                           FontFamily="Consolas"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="LATEST RELEASE (SHA-256)" FontSize="9" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="{Binding RemoteHashShort}" FontSize="12"
                                           FontFamily="Consolas"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Status -->
                        <TextBlock Text="{Binding UpdateStatus}" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap" Margin="0,14,0,0"/>

                        <!-- Download progress (green) -->
                        <Border Height="10" Background="#FF2A2A2A" CornerRadius="5"
                                ClipToBounds="True" Margin="0,12,0,0"
                                Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVisibility}}">
                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding DownloadProgress}"
                                         Background="Transparent" BorderThickness="0">
                                <ProgressBar.Template>
                                    <ControlTemplate TargetType="ProgressBar">
                                        <Grid>
                                            <Border x:Name="PART_Track" Background="Transparent"/>
                                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                                                    CornerRadius="5"
                                                    Background="{StaticResource GreenBrush}"/>
                                        </Grid>
                                    </ControlTemplate>
                                </ProgressBar.Template>
                            </ProgressBar>
                        </Border>

                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="🔄  Check for updates"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding CheckCommand}"/>
                            <Button Content="⬇  Update now"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding UpdateCommand}"
                                    Margin="10,0,0,0"
                                    Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
