<Window x:Class="WindowsTools.Views.InstallerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows Tools Setup"
        Width="580" Height="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Step sidebar -->
        <Border Grid.Column="0" Background="#FFF2F3F5" BorderBrush="#FFE0E0E0" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,22,16,22">
                    <TextBlock Text="🛠" FontSize="26" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Windows Tools" FontSize="15" FontWeight="Bold" Foreground="#FF1A1A1A"/>
                        <TextBlock Text="Setup" FontSize="11" Foreground="#FF808080"/>
                    </StackPanel>
                </StackPanel>

                <ItemsControl x:Name="StepsList" Grid.Row="1" Margin="16,4,12,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4,9">
                                <TextBlock Text="{Binding Indicator}" FontSize="14" Width="22"
                                           Foreground="{Binding IndicatorBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Title}" FontSize="13"
                                           Foreground="{Binding TitleBrush}"
                                           FontWeight="{Binding TitleWeight}"
                                           VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="140"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Grid.Row="2" Text="v1.0.0" FontSize="10"
                           Foreground="#FFA0A0A0" Margin="20,0,0,16"/>
            </Grid>
        </Border>

        <!-- Step content -->
        <Grid Grid.Column="1" Margin="32,28,32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock x:Name="StepTitle" Text="Welcome" FontSize="20" FontWeight="SemiBold"
                           Foreground="#FF1A1A1A"/>
                <Rectangle Height="1" Fill="#FFE5E5E5" Margin="0,14,0,0"/>
            </StackPanel>

            <TextBlock x:Name="StatusText" Grid.Row="1" Text="Preparing setup..."
                       FontSize="13" Foreground="#FF555555" TextWrapping="Wrap"
                       VerticalAlignment="Center" Margin="0,16"/>

            <!-- Green progress bar -->
            <Border Grid.Row="2" Height="20" Background="#FFECECEC" BorderBrush="#FFCFCFCF"
                    BorderThickness="1" CornerRadius="3" ClipToBounds="True">
                <ProgressBar x:Name="Progress" Minimum="0" Maximum="100" Value="0"
                             Background="Transparent" BorderThickness="0">
                    <ProgressBar.Template>
                        <ControlTemplate TargetType="ProgressBar">
                            <Grid>
                                <Border x:Name="PART_Track" Background="Transparent"/>
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="2">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FF5BC85B" Offset="0"/>
                                            <GradientStop Color="#FF3DA63D" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </ProgressBar.Template>
                </ProgressBar>
            </Border>

            <Grid Grid.Row="3" Margin="0,16,0,0">
                <TextBlock x:Name="PercentText" Text="0%" FontSize="11" Foreground="#FF909090"
                           VerticalAlignment="Center"/>
                <Button x:Name="NextButton" Content="Next" Width="110" Height="32"
                        HorizontalAlignment="Right"
                        Background="#FF3DA63D" Foreground="White" BorderThickness="0"
                        Cursor="Hand" FontSize="13" FontWeight="SemiBold"
                        Click="NextButton_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
