<Window x:Class="WindowsTools.Views.InstallerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows Tools Setup"
        Width="500" Height="320"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header banner -->
        <Border Grid.Row="0" Background="#FFF7F7F7" BorderBrush="#FFE0E0E0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="24,18">
                <TextBlock Text="🛠"
                           FontSize="34"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Windows Tools Setup"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#FF1A1A1A"/>
                    <TextBlock Text="Installing the application on your computer"
                               FontSize="12"
                               Foreground="#FF707070"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Body -->
        <StackPanel Grid.Row="1" Margin="32,0" VerticalAlignment="Center">
            <TextBlock x:Name="StatusText"
                       Text="Preparing..."
                       FontSize="14"
                       Foreground="#FF333333"
                       Margin="0,0,0,12"/>

            <!-- Green progress bar -->
            <Border Height="22"
                    Background="#FFECECEC"
                    BorderBrush="#FFCFCFCF"
                    BorderThickness="1"
                    CornerRadius="3"
                    ClipToBounds="True">
                <ProgressBar x:Name="Progress"
                             Minimum="0" Maximum="100" Value="0"
                             Background="Transparent"
                             BorderThickness="0">
                    <ProgressBar.Template>
                        <ControlTemplate TargetType="ProgressBar">
                            <Grid>
                                <Border x:Name="PART_Track" Background="Transparent"/>
                                <Border x:Name="PART_Indicator"
                                        HorizontalAlignment="Left"
                                        CornerRadius="2">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FF5BC85B" Offset="0"/>
                                            <GradientStop Color="#FF3DA63D" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </ProgressBar.Template>
                </ProgressBar>
            </Border>

            <TextBlock x:Name="PercentText"
                       Text="0%"
                       FontSize="12"
                       Foreground="#FF707070"
                       HorizontalAlignment="Right"
                       Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#FFF7F7F7" BorderBrush="#FFE0E0E0" BorderThickness="0,1,0,0">
            <TextBlock Text="Please wait while Windows Tools is installed..."
                       FontSize="11"
                       Foreground="#FF909090"
                       Margin="24,12"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
